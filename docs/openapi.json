  "info": {
    "contact": {},
    "description": "Self-describing OpenAPI 3.0 spec for nano-brain's non-MCP REST API",
    "title": "nano-brain REST API",
    "version": "1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/status": {
      "get": {
        "description": "Reports DB status, migration version, embedding queue depth, and harvester status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers.statusResponse"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Detailed server status",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/v1/graph/flowchart": {
      "post": {
        "description": "Resolves an HTTP route entry or handler symbol to its stored control-flow graph",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/handlers.flowchartRequest"
              }
            }
          },
          "description": "Flowchart query",
          "required": true,
          "x-originalParamName": "request"
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers.flowchartResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "WorkspaceAuth": []
          }
        ],
        "summary": "Get a function's control-flow graph",
        "tags": [
          "graph"
        ]
      }
    },
    "/api/v1/graph/impact": {
      "post": {
        "description": "Returns nodes that would be impacted (transitively depend on) a given node, up to max_depth",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/handlers.impactRequest"
              }
            }
          },
          "description": "Impact query",
          "required": true,
          "x-originalParamName": "request"
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers.impactResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "WorkspaceAuth": []
          }
        ],
        "summary": "Impact analysis for a graph node",
        "tags": [
          "graph"
        ]
      }
    },
    "/api/v1/graph/overview": {
      "post": {
        "description": "Returns the top-N most-connected nodes for the workspace and all edges between them",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/handlers.overviewRequest"
