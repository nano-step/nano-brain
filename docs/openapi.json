  "info": {
    "contact": {},
    "description": "Self-describing OpenAPI 3.0 spec for nano-brain's non-MCP REST API",
    "title": "nano-brain REST API",
    "version": "1.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/status": {
      "get": {
        "description": "Reports DB status, migration version, embedding queue depth, and harvester status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers.statusResponse"
                }
              }
            },
            "description": "OK"
          }
        },
        "summary": "Detailed server status",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/v1/flow/materialize": {
      "post": {
        "description": "Queues asynchronous flow-graph materialization for the workspace; returns immediately",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "WorkspaceRegisteredAuth": []
          },
          {
            "CSRFToken": []
          }
        ],
        "summary": "Trigger flow materialization for a workspace",
        "tags": [
          "flow"
        ]
      }
    },
    "/api/v1/graph/flow": {
      "post": {
        "description": "Loads all workspace edges, builds a flow starting from entry, and returns the node chain plus an optional Mermaid diagram",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/handlers.flowRequest"
              }
            }
          },
          "description": "Flow query",
          "required": true,
          "x-originalParamName": "request"
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers.flowResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "WorkspaceAuth": []
          }
        ],
        "summary": "Build a call-chain flow diagram from an entry point",
        "tags": [
          "flow"
        ]
      }
    },
    "/api/v1/graph/flow/endpoints": {
      "get": {
        "description": "Returns the HTTP-route entry edges available for flow tracing in a workspace",
