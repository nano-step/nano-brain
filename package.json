{
  "name": "nano-brain",
  "version": "2026.7.0-rc.11",
  "description": "Persistent memory and code intelligence for AI coding agents. Local MCP server with self-learning hybrid search (BM25 + vector + knowledge graph + LLM reranking), automatic session ingestion, codebase indexing, and 22 tools. Learns your preferences over time. Works with OpenCode, Claude, Cursor, Windsurf, and any MCP client.",
  "type": "module",
  "bin": {
    "nano-brain": "./bin/cli.js"
  },
  "main": "src/index.ts",
  "files": [
    "src/",
    "!src/eval/",
    "!src/web/node_modules/",
    "bin/",
    "dist/web/",
    ".opencode/",
    "SKILL.md",
    "AGENTS.md",
    "AGENTS_SNIPPET.md",
    "opencode-mcp.json",
    "docker-compose.yml",
    "config.default.yml"
  ],
  "scripts": {
    "dev": "bun src/index.ts",
    "start": "node bin/cli.js",
    "mcp": "node bin/cli.js mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "eval": "vitest run test/eval/",
    "lint:esm": "! grep -r 'require(' src/ --include='*.ts'",
    "build:web": "cd src/web && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "p-limit": "^7.3.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tree-sitter": "^0.22.4",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.21.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
